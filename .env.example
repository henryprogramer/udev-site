# Django
DJANGO_SECRET_KEY=trocar-em-producao-django
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver
DJANGO_DB_PATH=./data/udev_django.db

# Conta gestora (ativação por token)
MANAGER_REGISTRATION_EMAIL=udev.oficial@gmail.com
MANAGER_REGISTRATION_NAME=Equipe Gestora Udev
MANAGER_TOKEN_EXPIRY_MINUTES=15

# E-mail (desenvolvimento local com saída em arquivo)
EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend
DEFAULT_FROM_EMAIL=nao-responda@udev.local

# Frontend (preview e GitHub Pages)
NEXT_PUBLIC_STORE_URL=https://udevstartup.com.br
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
